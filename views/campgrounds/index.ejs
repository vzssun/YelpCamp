<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Index</title>
</head>
<body>
    <h1>Campgrounds</h1>
    <ul>
        <% campgrounds.forEach(campground => { %>
            <li><%= campground.title %></li>
            <button><a href="/campgrounds/<%= campground._id %>">View</a></button>
            <button><a href="/campgrounds/<%= campground._id %>/edit">Edit</a></button>
            <form action="/campgrounds/<%= campground._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit">Delete</button>
            </form>
        <% }) %>
    </ul>
</body>
</html>