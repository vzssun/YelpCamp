<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Campground</title>
</head>
<body>
    <h1>Edit Campground</h1>
    <form action="/campgrounds/<%= campground._id %>?_method=PUT" method="POST">
        <label for="name">Campground Name:</label>
        <input type="text" id="name" name="name" value="<%= campground.title %>" required>
        <br>
        <label for="image">Image URL:</label>
        <input type="text" id="image" name="image" value="<%= campground.image %>" required>
        <br>
        <label for="description">Description:</label>
        <textarea id="description" name="description" required><%= campground.description %></textarea>
        <br>
        <button type="submit">Update Campground</button>
    </form>
</body>
</html>